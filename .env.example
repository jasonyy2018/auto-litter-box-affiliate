# Site Configuration
NEXT_PUBLIC_SITE_URL=https://autolitterboxpro.com

# Amazon Affiliate Tag
NEXT_PUBLIC_AMAZON_TAG=autolitterbox-20

# Google Analytics (optional)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Google AdSense (optional)
# NEXT_PUBLIC_ADSENSE_ID=ca-pub-XXXXXXXXXX

# Pinterest API
PINTEREST_ACCESS_TOKEN=your_access_token_here
PINTEREST_BOARD_ID=your_default_board_id

# Pinterest Tag (conversion tracking, optional)
# NEXT_PUBLIC_PINTEREST_TAG_ID=your_tag_id

# Encryption Key (for securing API secrets in DB)
# Auto-generated from ADMIN_PASSWORD if not set
# ENCRYPTION_KEY=your-32-char-encryption-key-here

# PayPal (configured via Admin UI at /admin/paypal)
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=
# PAYPAL_MODE=sandbox

# Database (required for PayPal config storage)
DATABASE_URL=postgresql://user:pass@localhost:5432/autolitter
